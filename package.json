{
    "name":  "@repo/root",
    "private":  true,
    "version":  "0.0.0-ph55.1",
    "packageManager":  "pnpm@10.28.0",
    "engines":  {
                    "node":  "\u003e=22.0.0 \u003c25",
                    "pnpm":  "\u003e=10 \u003c11"
                },
    "scripts":  {
                    "bootstrap":  "node ./scripts/bootstrap/init-local.mjs",
                    "bootstrap:ci":  "node ./scripts/bootstrap/init-ci.mjs",
                    "doctor":  "node ./scripts/readiness/doctor.mjs",
                    "smoke":  "node ./scripts/readiness/smoke.mjs",
                    "smoke:ci":  "node ./scripts/readiness/smoke-ci.mjs",
                    "clean":  "turbo run clean --continue",
                    "build":  "turbo run build",
                    "dev":  "turbo run dev --parallel",
                    "lint":  "turbo run lint",
                    "lint:fix":  "eslint . --fix",
                    "typecheck":  "turbo run typecheck",
                    "test":  "turbo run test",
                    "test:unit":  "turbo run test:unit",
                    "test:integration":  "turbo run test:integration",
                    "test:workspace":  "vitest --workspace ./vitest.workspace.ts",
                    "format":  "prettier . --write",
                    "format:check":  "prettier . --check",
                    "check":  "pnpm lint \u0026\u0026 pnpm typecheck \u0026\u0026 pnpm test",
                    "check:full":  "pnpm lint \u0026\u0026 pnpm typecheck \u0026\u0026 pnpm test \u0026\u0026 pnpm build \u0026\u0026 pnpm smoke",
                    "repo:phase":  "node ./scripts/repo/print-phase.mjs",
                    "repo:tree":  "node ./scripts/repo/tree.mjs",
                    "repo:list":  "node ./scripts/repo/list-workspaces.mjs",
                    "repo:graph":  "node ./scripts/repo/graph.mjs",
                    "repo:ls":  "pnpm -r list --depth -1",
                    "release:prepare":  "node ./scripts/release/release-prepare.mjs",
                    "release:rc":  "node ./scripts/release/release-rc.mjs",
                    "release:stable":  "node ./scripts/release/release-stable.mjs",
                    "release:version-report":  "node ./scripts/release/version-report.mjs",
                    "changeset":  "changeset",
                    "version:packages":  "changeset version",
                    "publish:packages":  "changeset publish",
                    "backup:manifest":  "node ./scripts/backup/manifest.mjs",
                    "backup:quick":  "node ./scripts/backup/backup-quick.mjs",
                    "backup:full":  "node ./scripts/backup/backup-full.mjs",
                    "backup:zip:quick":  "node ./scripts/backup/backup-zip.mjs QUICK v1",
                    "backup:zip:full":  "node ./scripts/backup/backup-zip.mjs FULL v1",
                    "backup:verify:quick":  "node ./scripts/backup/verify-backup.mjs QUICK v1",
                    "backup:verify:full":  "node ./scripts/backup/verify-backup.mjs FULL v1",
                    "backup:quick:all":  "pnpm backup:quick \u0026\u0026 pnpm backup:zip:quick \u0026\u0026 pnpm backup:verify:quick",
                    "backup:full:all":  "pnpm backup:full \u0026\u0026 pnpm backup:zip:full \u0026\u0026 pnpm backup:verify:full",
                    "archive:ph55":  "node ./scripts/archive/archive-ph55.mjs",
                    "archive:rotate":  "node ./scripts/archive/rotate-history.mjs",
                    "archive:verify":  "node ./scripts/archive/verify-archive.mjs"
                },
    "devDependencies":  {
                            "@changesets/cli":  "^2.29.0",
                            "@types/node":  "^24.0.0",
                            "eslint":  "^9.0.0",
                            "prettier":  "^3.0.0",
                            "turbo":  "^2.5.0",
                            "typescript":  "^5.8.0",
                            "vitest":  "^3.0.0"
                        }
}